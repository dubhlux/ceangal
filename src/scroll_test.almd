// scroll_test — unit tests for scroll physics + scrollbar geometry

import self.scroll as scroll

fn approx(a: Float, b: Float, tol: Float) -> Bool =
  float.abs(a - b) < tol

// ── set_bounds ──

test "set_bounds clamps position" {
  scroll.reset()
  scroll.set_pos_y(-500.0)
  scroll.set_bounds(200.0, 100.0, 200.0, 100.0)
  assert(scroll.pos_y == 0.0)
}

test "set_bounds vertical scroll range" {
  scroll.reset()
  scroll.set_bounds(100.0, 500.0, 100.0, 200.0)
  assert(scroll.min_y == -300.0)
}

test "set_bounds horizontal scroll range" {
  scroll.reset()
  scroll.set_bounds(800.0, 100.0, 400.0, 100.0)
  assert(scroll.min_x == -400.0)
}

test "set_bounds no scroll when content fits" {
  scroll.reset()
  scroll.set_bounds(100.0, 100.0, 200.0, 200.0)
  assert(scroll.min_y == 0.0)
  assert(scroll.min_x == 0.0)
}

// ── wheel ──

test "wheel_y sets position and velocity" {
  scroll.reset()
  scroll.set_bounds(100.0, 1000.0, 100.0, 500.0)
  scroll.wheel_y(-50.0)
  assert(scroll.pos_y == -50.0)
  assert(scroll.vel_y == -100.0)
  assert(scroll.state_y == 1)
  assert(scroll.bar_opacity_y == 1.0)
}

test "wheel_x sets position and velocity" {
  scroll.reset()
  scroll.set_bounds(1000.0, 100.0, 500.0, 100.0)
  scroll.wheel_x(-30.0)
  assert(scroll.pos_x == -30.0)
  assert(scroll.vel_x == -60.0)
  assert(scroll.state_x == 1)
}

test "wheel overscroll triggers bouncing" {
  scroll.reset()
  scroll.set_bounds(100.0, 200.0, 100.0, 200.0)
  scroll.wheel_y(10.0)
  assert(scroll.state_y == 2)
}

// ── tick: coasting ──

test "coasting decays velocity" {
  scroll.reset()
  scroll.set_bounds(100.0, 2000.0, 100.0, 500.0)
  scroll.set_pos_y(-100.0)
  scroll.set_vel_y(-500.0)
  scroll.set_state_y(1)
  let before_vel = scroll.vel_y
  let _ = scroll.tick(0.016)
  assert(float.abs(scroll.vel_y) < float.abs(before_vel))
  assert(scroll.pos_y < -100.0)
}

test "coasting stops at threshold" {
  scroll.reset()
  scroll.set_bounds(100.0, 2000.0, 100.0, 500.0)
  scroll.set_pos_y(-100.0)
  scroll.set_vel_y(-0.1)
  scroll.set_state_y(1)
  let _ = scroll.tick(0.016)
  assert(scroll.state_y == 0)
}

// ── tick: bouncing ──

test "bouncing returns to boundary" {
  scroll.reset()
  scroll.set_bounds(100.0, 200.0, 100.0, 200.0)
  scroll.set_pos_y(50.0)
  scroll.set_state_y(2)
  for _ in 0..200 { let _ = scroll.tick(0.016) }
  assert(approx(scroll.pos_y, 0.0, 1.0))
  assert(scroll.state_y == 0)
}

test "bouncing at bottom returns to min" {
  scroll.reset()
  scroll.set_bounds(100.0, 1000.0, 100.0, 500.0)
  scroll.set_pos_y(-550.0)
  scroll.set_state_y(2)
  for _ in 0..200 { let _ = scroll.tick(0.016) }
  assert(approx(scroll.pos_y, -500.0, 1.0))
  assert(scroll.state_y == 0)
}

// ── drag + release ──

test "drag_y moves position" {
  scroll.reset()
  scroll.set_bounds(100.0, 1000.0, 100.0, 500.0)
  scroll.drag_y(-20.0)
  assert(scroll.pos_y == -20.0)
}

test "drag_y rubber band when overscrolled" {
  scroll.reset()
  scroll.set_bounds(100.0, 1000.0, 100.0, 500.0)
  scroll.set_pos_y(50.0)
  let before = scroll.pos_y
  scroll.drag_y(10.0)
  assert(scroll.pos_y - before < 10.0)
}

test "release_y starts coasting" {
  scroll.reset()
  scroll.set_bounds(100.0, 1000.0, 100.0, 500.0)
  scroll.set_pos_y(-100.0)
  scroll.release_y(-500.0)
  assert(scroll.state_y == 1)
  assert(scroll.vel_y == -500.0)
}

test "release_y caps velocity" {
  scroll.reset()
  scroll.set_bounds(100.0, 1000.0, 100.0, 500.0)
  scroll.release_y(-99999.0)
  assert(float.abs(scroll.vel_y) <= 6001.0)
}

// ── scrollbar geometry ──

test "scrollbar_thumb_y size and position at top" {
  scroll.reset()
  scroll.set_bounds(100.0, 1000.0, 100.0, 500.0)
  let t = scroll.scrollbar_thumb_y(500.0, 1000.0)
  assert(approx(t.height, 250.0, 1.0))
  assert(approx(t.top, 0.0, 1.0))
}

test "scrollbar_thumb_y at bottom" {
  scroll.reset()
  scroll.set_bounds(100.0, 1000.0, 100.0, 500.0)
  scroll.set_pos_y(-500.0)
  let t = scroll.scrollbar_thumb_y(500.0, 1000.0)
  assert(approx(t.top, 250.0, 1.0))
}

test "scrollbar_thumb_y no scroll returns zero" {
  scroll.reset()
  scroll.set_bounds(100.0, 100.0, 100.0, 100.0)
  let t = scroll.scrollbar_thumb_y(100.0, 100.0)
  assert(t.height == 0.0)
}

test "scrollbar_thumb_x size" {
  scroll.reset()
  scroll.set_bounds(2000.0, 100.0, 500.0, 100.0)
  let t = scroll.scrollbar_thumb_x(500.0, 2000.0)
  assert(approx(t.width, 125.0, 1.0))
}

test "scrollbar_set_y jumps to fraction" {
  scroll.reset()
  scroll.set_bounds(100.0, 1000.0, 100.0, 500.0)
  scroll.scrollbar_set_y(0.5, 1000.0, 500.0)
  assert(approx(scroll.pos_y, -250.0, 1.0))
}

// ── track tap ──

test "track_tap_y jumps to click position" {
  scroll.reset()
  scroll.set_bounds(100.0, 1000.0, 100.0, 500.0)
  scroll.track_tap_y(250.0, 500.0, 1000.0)
  assert(approx(scroll.pos_y, -250.0, 1.0))
  assert(scroll.state_y == 0)
}

// ── scrollbar fade ──

test "scrollbar fades after idle delay" {
  scroll.reset()
  scroll.set_bounds(100.0, 1000.0, 100.0, 500.0)
  scroll.wheel_y(-10.0)
  assert(scroll.bar_opacity_y == 1.0)
  scroll.set_state_y(0)
  scroll.set_vel_y(0.0)
  for _ in 0..82 { let _ = scroll.tick(0.016) }
  assert(scroll.bar_opacity_y < 1.0)
  for _ in 0..50 { let _ = scroll.tick(0.016) }
  assert(scroll.bar_opacity_y < 0.02)
}

// ── powf ──

test "powf computes float exponentiation" {
  assert(approx(scroll.powf(2.0, 3.0), 8.0, 0.001))
  assert(approx(scroll.powf(0.95, 60.0), 0.0461, 0.001))
  assert(approx(scroll.powf(10.0, 0.0), 1.0, 0.001))
}

// ── full cycle ──

test "wheel coast stop cycle" {
  scroll.reset()
  scroll.set_bounds(100.0, 2000.0, 100.0, 500.0)
  scroll.wheel_y(-30.0)
  var running = 1
  var ticks = 0
  while running == 1 and ticks < 500 {
    running = scroll.tick(0.016)
    ticks = ticks + 1
  }
  assert(scroll.state_y == 0)
  assert(scroll.pos_y < 0.0)
  assert(float.abs(scroll.vel_y) < 0.5)
}
