test "yoga: align_self_center_column" {
  let root = lay.col([lay.leaf(10.0, 10.0) |> lay.with_align_self(lay.ALIGN_CENTER)])
    |> lay.with_size(100.0, 100.0)
  let r = lay.layout(root, 100.0, 100.0)
  assert(approx(r[1].x, 45.0))
}

test "yoga: align_self_flex_end_column" {
  let root = lay.col([lay.leaf(10.0, 10.0) |> lay.with_align_self(lay.ALIGN_END)])
    |> lay.with_size(100.0, 100.0)
  let r = lay.layout(root, 100.0, 100.0)
  assert(approx(r[1].x, 90.0))
}

test "yoga: align_self_flex_start_column" {
  let root = lay.col([lay.leaf(10.0, 10.0) |> lay.with_align_self(lay.ALIGN_START)])
    |> lay.with_size(100.0, 100.0)
  let r = lay.layout(root, 100.0, 100.0)
  assert(approx(r[1].x, 0.0))
