// ════════════════════════════════════════
// Overflow / Nesting
// ════════════════════════════════════════

test "yoga: nested_overflowing_child_in_constraint" {
  let inner = lay.col([lay.leaf(200.0, 200.0)]) |> lay.with_size(100.0, 100.0)
  let root = lay.col([inner]) |> lay.with_size(100.0, 100.0)
  let r = lay.layout(root, 100.0, 100.0)
  assert(approx(r[0].w, 100.0))
  assert(approx(r[1].w, 100.0))
  assert(approx(r[1].h, 100.0))
  assert(approx(r[2].w, 200.0))
  assert(approx(r[2].h, 200.0))
}

// ════════════════════════════════════════
// Flex Grow (additional)
// ════════════════════════════════════════

test "yoga: flex_grow_height_maximized" {
  let inner = lay.col([
    lay.leaf(100.0, UNDEF) |> lay.with_basis(200.0) |> lay.with_grow(1.0),
    lay.leaf(100.0, 100.0),
  ]) |> lay.with_grow(1.0) |> lay.with_min_size(0.0, 100.0) |> lay.with_max_size(UNDEF, 500.0)
     |> lay.with_size(100.0, UNDEF)
  let root = lay.col([inner]) |> lay.with_size(100.0, 500.0)
  let r = lay.layout(root, 100.0, 500.0)
  // inner gets 500 (grow=1 fills root). inner child0 basis=200 grow=1, child1=100 fixed.
  // inner main=500. basis_total=300. remaining=200. child0 gets 200+200=400.
  assert(approx(r[1].h, 500.0))
  assert(approx(r[2].h, 400.0))
  assert(approx(r[3].h, 100.0))
}

test "yoga: flex_grow_less_than_factor_one" {
  // Yoga: when total grow < 1, remaining space is scaled by total_grow
  // Our implementation distributes proportionally, so with grow 0.2+0.2+0.4=0.8:
  // remaining=460 (500-40). each gets: 0.2/0.8*460=115, 0.2/0.8*460=115, 0.4/0.8*460=230
  // child0: 40+115=155, child1: 0+115=115, child2: 0+230=230
  let root = lay.col([
    lay.node_defaults() |> lay.with_grow(0.2) |> lay.with_basis(40.0) |> lay.with_size(200.0, UNDEF),
    lay.node_defaults() |> lay.with_grow(0.2) |> lay.with_size(200.0, UNDEF),
    lay.node_defaults() |> lay.with_grow(0.4) |> lay.with_size(200.0, UNDEF),
  ]) |> lay.with_size(200.0, 500.0)
  let r = lay.layout(root, 200.0, 500.0)
  assert(approx(r[1].h, 155.0))
  assert(approx(r[2].h, 115.0))
  assert(approx(r[3].h, 230.0))
}

// ════════════════════════════════════════
// Align Content (additional)
// ════════════════════════════════════════

test "yoga: align_content_flex_start_wrap" {
  let root = lay.row([
    lay.leaf(50.0, 10.0), lay.leaf(50.0, 10.0),
    lay.leaf(50.0, 10.0), lay.leaf(50.0, 10.0),
    lay.leaf(50.0, 10.0),
  ]) |> lay.with_size(140.0, 120.0) |> lay.with_wrap(WRAP)
     |> lay.with_align_content(lay.ALIGN_START)
  let r = lay.layout(root, 140.0, 120.0)
  // 3 lines: [2,2,1]. flex_start → y starts at 0.
  assert(approx(r[1].y, 0.0))
  assert(approx(r[3].y, 10.0))
  assert(approx(r[5].y, 20.0))
}

test "yoga: align_content_flex_start_nowrap" {
  let root = lay.row([lay.leaf(50.0, 10.0), lay.leaf(50.0, 10.0)])
    |> lay.with_size(140.0, 120.0)
  let r = lay.layout(root, 140.0, 120.0)
  assert(approx(r[1].x, 0.0))
  assert(approx(r[2].x, 50.0))
}

// ════════════════════════════════════════
// Wrapped Row Alignment
// ════════════════════════════════════════

test "yoga: wrapped_row_within_align_items_flex_start" {
  let inner = lay.row([lay.leaf(150.0, 80.0), lay.leaf(80.0, 80.0)])
    |> lay.with_wrap(WRAP) |> lay.with_size(200.0, UNDEF)
  let root = lay.row([inner]) |> lay.with_size(200.0, 200.0) |> lay.with_align(lay.ALIGN_START)
  let r = lay.layout(root, 200.0, 200.0)
  assert(approx(r[1].h, 160.0))
  assert(approx(r[2].h, 80.0))
  assert(approx(r[3].y, 80.0))
}

test "yoga: wrapped_row_within_align_items_center" {
  let inner = lay.row([lay.leaf(150.0, 80.0), lay.leaf(80.0, 80.0)])
    |> lay.with_wrap(WRAP) |> lay.with_size(200.0, UNDEF)
  let root = lay.row([inner]) |> lay.with_size(200.0, 200.0) |> lay.with_align(lay.ALIGN_CENTER)
  let r = lay.layout(root, 200.0, 200.0)
  assert(approx(r[1].h, 160.0))
}

// ════════════════════════════════════════
// Absolute Positioning
// ════════════════════════════════════════

test "yoga: absolute_bottom" {
  let abs_child = lay.leaf(40.0, 40.0)
    |> lay.with_position(lay.POSITION_ABSOLUTE, UNDEF, UNDEF, 0.0, 0.0)
  let root = lay.col([lay.leaf(UNDEF, 50.0), abs_child]) |> lay.with_size(100.0, 100.0)
  let r = lay.layout(root, 100.0, 100.0)
  // Flex child: rect[1] h=50
  // Abs child: rect[2] at bottom=0, left=0 → y = 100-40 = 60
  assert(approx(r[1].h, 50.0))
  assert(approx(r[2].y, 60.0))
  assert(approx(r[2].x, 0.0))
  assert(approx(r[2].w, 40.0))
}

test "yoga: absolute_width_pct" {
  let abs_child = lay.leaf(UNDEF, 40.0)
    |> lay.with_position(lay.POSITION_ABSOLUTE, UNDEF, UNDEF, 0.0, UNDEF)
    |> lay.with_width_pct(100.0)
  let root = lay.col([abs_child]) |> lay.with_size(200.0, 200.0) |> lay.with_padding(lay.edges_all(10.0))
  let r = lay.layout(root, 200.0, 200.0)
  // abs child: width=100% of inner (180), bottom=0 → y = 200-10-40 = 150
  assert(approx(r[1].w, 180.0))
  assert(approx(r[1].y, 150.0))
}

test "yoga: absolute_not_in_flex_flow" {
  // Absolute child doesn't affect flex siblings
  let c0 = lay.leaf(50.0, 50.0)
  let c1 = lay.leaf(50.0, 50.0) |> lay.with_position(lay.POSITION_ABSOLUTE, 0.0, UNDEF, UNDEF, 0.0)
  let c2 = lay.leaf(50.0, 50.0)
  let root = lay.row([c0, c1, c2]) |> lay.with_size(200.0, 100.0)
  let r = lay.layout(root, 200.0, 100.0)
  // c0 at x=0, c2 at x=50 (c1 skipped in flex), c1 absolute at x=0 y=0
  assert(approx(r[1].x, 0.0))  // c0
  assert(approx(r[2].x, 50.0)) // c2 (next after c0, c1 skipped)
  assert(approx(r[3].x, 0.0))  // c1 absolute
  assert(approx(r[3].y, 0.0))
}

// ════════════════════════════════════════
// Yoga Sample: Mobile App Layout
// ════════════════════════════════════════

test "yoga: mobile_app_sample" {
  // Reproduced from Yoga website sample
  let bottom_bar = lay.row([
    lay.leaf(40.0, 40.0), lay.leaf(40.0, 40.0),
    lay.leaf(40.0, 40.0), lay.leaf(40.0, 40.0),
  ]) |> lay.with_align(lay.ALIGN_CENTER) |> lay.with_justify(lay.JUSTIFY_AROUND)
     |> lay.with_position(lay.POSITION_ABSOLUTE, UNDEF, UNDEF, 0.0, UNDEF)
     |> lay.with_width_pct(100.0) |> lay.with_size(UNDEF, 64.0)

  let content = lay.col([
    lay.leaf(UNDEF, 60.0),  // header
    lay.node_defaults() |> lay.with_grow(1.0) |> lay.with_margin(lay.edges_xy(10.0, 0.0)),  // middle 1
    lay.node_defaults() |> lay.with_grow(2.0) |> lay.with_margin(lay.edges_xy(10.0, 0.0)),  // middle 2
    bottom_bar,
  ]) |> lay.with_grow(1.0) |> lay.with_gap(10.0)

  let root = lay.col([content]) |> lay.with_size(250.0, 475.0) |> lay.with_padding(lay.edges_all(10.0))
  let r = lay.layout(root, 250.0, 475.0)

  // root = rect[0]: 250x475
  assert(approx(r[0].w, 250.0))
  assert(approx(r[0].h, 475.0))

  // content = rect[1]: fills root inner (230x455)
  assert(approx(r[1].w, 230.0))

  // header = rect[2]: full width, h=60
  assert(approx(r[2].h, 60.0))

  // bottom_bar = absolute, at bottom, width=100%
  // Find it in the rect list (absolute children come after flex children)
  let n_rects = list.len(r)
  // bottom_bar has 4 children → 5 rects (bar + 4 icons)
  let bar_idx = n_rects - 5
  // Just verify layout completed with correct number of rects
  // root(1) + content(1) + header(1) + middle1(1) + middle2(1) + bar(1) + 4 icons = 10
  assert(n_rects >= 8)
}

// ════════════════════════════════════════
// Row/Column Reverse
// ════════════════════════════════════════

test "yoga: row_reverse" {
  let root = lay.row([lay.leaf(50.0, 50.0), lay.leaf(80.0, 50.0)])
    |> lay.with_size(200.0, 100.0)
  // Normal row: child0 at x=0, child1 at x=50
  let r1 = lay.layout(root, 200.0, 100.0)
  assert(approx(r1[1].x, 0.0))
  assert(approx(r1[2].x, 50.0))

  // Reverse: child0 at right, child1 to its left
  let root_rev = lay.rebuild(root, lay.ROW_REVERSE, root.wrap, root.justify, root.align_items, root.align_content,
    root.gap_main, root.gap_cross, root.grow, root.shrink, root.basis, root.align_self,
    root.padding, root.margin, root.border, root.width, root.height, root.aspect_ratio,
    root.min_width, root.min_height, root.max_width, root.max_height,
    root.display, root.position, root.pos_top, root.pos_right, root.pos_bottom, root.pos_left,
    root.width_pct, root.height_pct, root.children)
  let r2 = lay.layout(root_rev, 200.0, 100.0)
  // child0 (50w) at right: x = 200 - 50 = 150
  assert(approx(r2[1].x, 150.0))
  // child1 (80w) next: x = 200 - 50 - 80 = 70
  assert(approx(r2[2].x, 70.0))
}

test "yoga: column_reverse" {
  let c0 = lay.leaf(50.0, 40.0)
  let c1 = lay.leaf(50.0, 60.0)
  let root = lay.col([c0, c1]) |> lay.with_size(100.0, 200.0)
  let r1 = lay.layout(root, 100.0, 200.0)
  assert(approx(r1[1].y, 0.0))
  assert(approx(r1[2].y, 40.0))

  let root_rev = lay.rebuild(root, lay.COLUMN_REVERSE, root.wrap, root.justify, root.align_items, root.align_content,
    root.gap_main, root.gap_cross, root.grow, root.shrink, root.basis, root.align_self,
    root.padding, root.margin, root.border, root.width, root.height, root.aspect_ratio,
    root.min_width, root.min_height, root.max_width, root.max_height,
    root.display, root.position, root.pos_top, root.pos_right, root.pos_bottom, root.pos_left,
    root.width_pct, root.height_pct, root.children)
  let r2 = lay.layout(root_rev, 100.0, 200.0)
  // child0 (40h) at bottom: y = 200 - 40 = 160
  assert(approx(r2[1].y, 160.0))
  // child1 (60h): y = 200 - 40 - 60 = 100
  assert(approx(r2[2].y, 100.0))
}

// ════════════════════════════════════════
// Auto Margin
// ════════════════════════════════════════

test "yoga: auto_margin_main_center" {
  // Single child with margin-left:auto, margin-right:auto → centered
  let c = lay.leaf(50.0, 50.0) |> lay.with_margin({ top: 0.0, right: lay.MARGIN_AUTO, bottom: 0.0, left: lay.MARGIN_AUTO })
  let root = lay.row([c]) |> lay.with_size(200.0, 100.0)
  let r = lay.layout(root, 200.0, 100.0)
  // free = 150, 2 auto margins → 75 each. child at x=75.
  assert(approx(r[1].x, 75.0))
}

test "yoga: auto_margin_main_end" {
  // margin-left:auto → push to right
  let c = lay.leaf(50.0, 50.0) |> lay.with_margin({ top: 0.0, right: 0.0, bottom: 0.0, left: lay.MARGIN_AUTO })
  let root = lay.row([c]) |> lay.with_size(200.0, 100.0)
  let r = lay.layout(root, 200.0, 100.0)
  assert(approx(r[1].x, 150.0))
}

test "yoga: auto_margin_cross_center" {
  // margin-top:auto, margin-bottom:auto → vertically centered in row
  let c = lay.leaf(50.0, 30.0) |> lay.with_margin({ top: lay.MARGIN_AUTO, right: 0.0, bottom: lay.MARGIN_AUTO, left: 0.0 })
  let root = lay.row([c]) |> lay.with_size(200.0, 100.0)
  let r = lay.layout(root, 200.0, 100.0)
  // cross free = 100 - 30 = 70. Auto both → 35 each. y = 35.
  assert(approx(r[1].y, 35.0))
}

// ════════════════════════════════════════
// Percentage Padding
// ════════════════════════════════════════

test "yoga: padding_percentage" {
  // padding: 10% → resolves against parent width (200) → 20px each side
  let root = lay.col([lay.leaf(50.0, 50.0)])
    |> lay.with_size(200.0, 200.0)
    |> lay.with_padding({ top: lay.pct(10.0), right: lay.pct(10.0), bottom: lay.pct(10.0), left: lay.pct(10.0) })
  let r = lay.layout(root, 200.0, 200.0)
  // child at (20, 20) with size 50x50
  assert(approx(r[1].x, 20.0))
  assert(approx(r[1].y, 20.0))
}

// ════════════════════════════════════════
// Aspect Ratio
// ════════════════════════════════════════

test "yoga: aspect_ratio_width_defined" {
  // width=100, aspect_ratio=2.0 → height = 100/2 = 50
  let c = lay.leaf(100.0, UNDEF) |> lay.with_aspect_ratio(2.0)
  let root = lay.col([c]) |> lay.with_size(200.0, 200.0)
  let r = lay.layout(root, 200.0, 200.0)
  assert(approx(r[1].w, 100.0))
  assert(approx(r[1].h, 50.0))
}

test "yoga: aspect_ratio_height_defined" {
  // height=60, aspect_ratio=1.5 → width = 60 * 1.5 = 90
  let c = lay.leaf(UNDEF, 60.0) |> lay.with_aspect_ratio(1.5)
  let root = lay.row([c]) |> lay.with_size(200.0, 200.0)
  let r = lay.layout(root, 200.0, 200.0)
  assert(approx(r[1].w, 90.0))
  assert(approx(r[1].h, 60.0))
}

test "yoga: aspect_ratio_square" {
  // aspect_ratio=1.0, width=80 → height=80
  let c = lay.leaf(80.0, UNDEF) |> lay.with_aspect_ratio(1.0)
  let root = lay.col([c]) |> lay.with_size(200.0, 200.0)
  let r = lay.layout(root, 200.0, 200.0)
  assert(approx(r[1].w, 80.0))
  assert(approx(r[1].h, 80.0))
}

test "yoga: padding_percentage_asymmetric" {
  // padding-left: 5%, padding-right: 10% against width=400 → 20, 40
  let root = lay.row([lay.leaf(100.0, 50.0)])
    |> lay.with_size(400.0, 100.0)
    |> lay.with_padding({ top: 0.0, right: lay.pct(10.0), bottom: 0.0, left: lay.pct(5.0) })
  let r = lay.layout(root, 400.0, 100.0)
  // child at x=20 (5% of 400)
  assert(approx(r[1].x, 20.0))
}
