// ceangal layout tests — ported from facebook/yoga generated tests
//
// Each test matches a Yoga C++ test case name.
// Expected values extracted from Yoga LTR assertions.

import self.layout as lay

fn approx(a: Float, b: Float) -> Bool = float.abs(a - b) < 0.5

// Local constants to avoid cross-module const resolution issues
let UNDEF = -1.0
let WRAP = 1

// ════════════════════════════════════════
// Flex Basis + Grow
// ════════════════════════════════════════

test "yoga: flex_basis_flex_grow_column" {
  let root = lay.col([
    lay.node_defaults() |> lay.with_basis(50.0) |> lay.with_grow(1.0),
    lay.node_defaults() |> lay.with_grow(1.0),
  ]) |> lay.with_size(100.0, 100.0)
  let r = lay.layout(root, 100.0, 100.0)
  assert(approx(r[1].h, 75.0))
  assert(approx(r[2].y, 75.0))
  assert(approx(r[2].h, 25.0))
}

test "yoga: flex_basis_flex_grow_row" {
  let root = lay.row([
    lay.node_defaults() |> lay.with_basis(50.0) |> lay.with_grow(1.0),
    lay.node_defaults() |> lay.with_grow(1.0),
  ]) |> lay.with_size(100.0, 100.0)
  let r = lay.layout(root, 100.0, 100.0)
  assert(approx(r[1].w, 75.0))
  assert(approx(r[2].x, 75.0))
  assert(approx(r[2].w, 25.0))
}

// ════════════════════════════════════════
// Flex Shrink
// ════════════════════════════════════════

test "yoga: flex_shrink_flex_grow_row" {
  let root = lay.row([
    lay.leaf(500.0, 100.0) |> lay.with_shrink(1.0),
    lay.leaf(500.0, 100.0) |> lay.with_shrink(1.0),
  ]) |> lay.with_size(500.0, 500.0)
  let r = lay.layout(root, 500.0, 500.0)
  assert(approx(r[1].w, 250.0))
  assert(approx(r[2].x, 250.0))
  assert(approx(r[2].w, 250.0))
}

test "yoga: flex_basis_flex_shrink_column" {
  let root = lay.col([
    lay.node_defaults() |> lay.with_basis(100.0) |> lay.with_shrink(1.0),
    lay.node_defaults() |> lay.with_basis(50.0),
  ]) |> lay.with_size(100.0, 100.0)
  let r = lay.layout(root, 100.0, 100.0)
  assert(approx(r[1].h, 50.0))
  assert(approx(r[2].y, 50.0))
  assert(approx(r[2].h, 50.0))
}

test "yoga: flex_basis_flex_shrink_row" {
  let root = lay.row([
    lay.node_defaults() |> lay.with_basis(100.0) |> lay.with_shrink(1.0),
    lay.node_defaults() |> lay.with_basis(50.0),
  ]) |> lay.with_size(100.0, 100.0)
  let r = lay.layout(root, 100.0, 100.0)
  assert(approx(r[1].w, 50.0))
  assert(approx(r[2].x, 50.0))
  assert(approx(r[2].w, 50.0))
}

test "yoga: flex_shrink_weighted_by_basis" {
  // Yoga: shrink is weighted by basis. child0 basis=100 shrink=1, child1 basis=200 shrink=1
  // Container 200 wide. Total basis=300, overflow=-100.
  // shrink_scaled: child0=100, child1=200. total=300.
  // child0: 100 + (-100 * 100/300) = 100 - 33.3 = 66.7
  // child1: 200 + (-100 * 200/300) = 200 - 66.7 = 133.3
  let root = lay.row([
    lay.node_defaults() |> lay.with_basis(100.0) |> lay.with_shrink(1.0),
    lay.node_defaults() |> lay.with_basis(200.0) |> lay.with_shrink(1.0),
  ]) |> lay.with_size(200.0, 100.0)
  let r = lay.layout(root, 200.0, 100.0)
  assert(approx(r[1].w, 66.7))
  assert(approx(r[2].w, 133.3))
}

// ════════════════════════════════════════
// Flex Direction
// ════════════════════════════════════════

test "yoga: flex_direction_column_no_height" {
  // Root has no height — sizes to content
  let root = lay.col([
    lay.leaf(UNDEF, 10.0),
    lay.leaf(UNDEF, 10.0),
    lay.leaf(UNDEF, 10.0),
  ]) |> lay.with_size(100.0, UNDEF)
  let r = lay.layout(root, 100.0, UNDEF)
  assert(approx(r[0].h, 30.0))
  assert(approx(r[1].h, 10.0))
  assert(approx(r[2].y, 10.0))
  assert(approx(r[3].y, 20.0))
}

test "yoga: flex_direction_row_no_width" {
  let root = lay.row([
    lay.leaf(10.0, UNDEF),
    lay.leaf(10.0, UNDEF),
    lay.leaf(10.0, UNDEF),
  ]) |> lay.with_size(UNDEF, 100.0)
  let r = lay.layout(root, UNDEF, 100.0)
  assert(approx(r[0].w, 30.0))
  assert(approx(r[1].w, 10.0))
  assert(approx(r[2].x, 10.0))
  assert(approx(r[3].x, 20.0))
}

// ════════════════════════════════════════
// Display None
// ════════════════════════════════════════

test "yoga: display_none" {
  let root = lay.row([
    lay.node_defaults() |> lay.with_grow(1.0),
    lay.node_defaults() |> lay.with_grow(1.0) |> lay.with_display(lay.DISPLAY_NONE),
  ]) |> lay.with_size(100.0, 100.0)
  let r = lay.layout(root, 100.0, 100.0)
  // display:none child produces no rect, so only root + visible child
  assert(approx(r[1].w, 100.0))
  assert(approx(r[1].h, 100.0))
}

test "yoga: display_none_fixed_size" {
  let root = lay.row([
    lay.node_defaults() |> lay.with_grow(1.0),
    lay.leaf(20.0, 20.0) |> lay.with_display(lay.DISPLAY_NONE),
  ]) |> lay.with_size(100.0, 100.0)
  let r = lay.layout(root, 100.0, 100.0)
  assert(approx(r[1].w, 100.0))
}

// ════════════════════════════════════════
// Margin
// ════════════════════════════════════════

test "yoga: margin_start" {
  let c = lay.leaf(10.0, UNDEF) |> lay.with_margin({ top: 0.0, right: 0.0, bottom: 0.0, left: 10.0 })
  let root = lay.row([c]) |> lay.with_size(100.0, 100.0)
  let r = lay.layout(root, 100.0, 100.0)
  assert(approx(r[1].x, 10.0))
  assert(approx(r[1].w, 10.0))
}

test "yoga: margin_top" {
  let c = lay.leaf(UNDEF, 10.0) |> lay.with_margin({ top: 10.0, right: 0.0, bottom: 0.0, left: 0.0 })
  let root = lay.col([c]) |> lay.with_size(100.0, 100.0)
  let r = lay.layout(root, 100.0, 100.0)
  assert(approx(r[1].y, 10.0))
  assert(approx(r[1].h, 10.0))
}

test "yoga: margin_end_with_justify_end" {
  let c = lay.leaf(10.0, UNDEF) |> lay.with_margin({ top: 0.0, right: 10.0, bottom: 0.0, left: 0.0 })
  let root = lay.row([c]) |> lay.with_size(100.0, 100.0) |> lay.with_justify(lay.JUSTIFY_END)
  let r = lay.layout(root, 100.0, 100.0)
  assert(approx(r[1].x, 80.0))  // 100 - 10 - 10(margin)
}

test "yoga: margin_and_flex_row" {
  let c = lay.node_defaults() |> lay.with_grow(1.0) |> lay.with_margin({ top: 0.0, right: 10.0, bottom: 0.0, left: 10.0 })
  let root = lay.row([c]) |> lay.with_size(100.0, 100.0)
  let r = lay.layout(root, 100.0, 100.0)
  assert(approx(r[1].x, 10.0))
  assert(approx(r[1].w, 80.0))
}

test "yoga: margin_and_flex_column" {
  let c = lay.node_defaults() |> lay.with_grow(1.0) |> lay.with_margin({ top: 10.0, right: 0.0, bottom: 10.0, left: 0.0 })
  let root = lay.col([c]) |> lay.with_size(100.0, 100.0)
  let r = lay.layout(root, 100.0, 100.0)
  assert(approx(r[1].y, 10.0))
  assert(approx(r[1].h, 80.0))
}

// ════════════════════════════════════════
// Min / Max Dimensions
// ════════════════════════════════════════

test "yoga: max_width" {
  let c = lay.leaf(UNDEF, 10.0) |> lay.with_max_size(50.0, UNDEF)
  let root = lay.col([c]) |> lay.with_size(100.0, 100.0)
  let r = lay.layout(root, 100.0, 100.0)
  assert(approx(r[1].w, 50.0))
}

test "yoga: max_height" {
  let c = lay.leaf(10.0, UNDEF) |> lay.with_max_size(UNDEF, 50.0)
  let root = lay.row([c]) |> lay.with_size(100.0, 100.0)
  let r = lay.layout(root, 100.0, 100.0)
  assert(approx(r[1].h, 50.0))
}

test "yoga: min_width" {
  let c = lay.leaf(UNDEF, 10.0) |> lay.with_min_size(50.0, 0.0)
  let root = lay.col([c]) |> lay.with_size(30.0, 100.0)
  let r = lay.layout(root, 30.0, 100.0)
  assert(approx(r[1].w, 50.0))
}

test "yoga: flex_grow_within_max_width" {
  let c = lay.node_defaults() |> lay.with_grow(1.0) |> lay.with_max_size(50.0, UNDEF)
  let root = lay.row([c]) |> lay.with_size(100.0, 100.0)
  let r = lay.layout(root, 100.0, 100.0)
  assert(approx(r[1].w, 50.0))
}

// ════════════════════════════════════════
// Gap
// ════════════════════════════════════════

test "yoga: column_gap_inflexible" {
  let root = lay.row([
    lay.leaf(20.0, UNDEF),
    lay.leaf(20.0, UNDEF),
    lay.leaf(20.0, UNDEF),
  ]) |> lay.with_size(80.0, 100.0) |> lay.with_gap(10.0)
  let r = lay.layout(root, 80.0, 100.0)
  assert(approx(r[1].x, 0.0))
  assert(approx(r[2].x, 30.0))
  assert(approx(r[3].x, 60.0))
}

test "yoga: column_gap_flexible" {
  let c = lay.node_defaults() |> lay.with_grow(1.0) |> lay.with_shrink(1.0) |> lay.with_basis(0.0)
  let root = lay.row([c, c, c]) |> lay.with_size(80.0, 100.0) |> lay.with_gap(10.0)
  let r = lay.layout(root, 80.0, 100.0)
  // 80 - 2*10(gap) = 60 / 3 = 20 each
  assert(approx(r[1].w, 20.0))
  assert(approx(r[2].x, 30.0))
  assert(approx(r[2].w, 20.0))
  assert(approx(r[3].x, 60.0))
}

// ════════════════════════════════════════
// Flex Wrap
// ════════════════════════════════════════

test "yoga: wrap_row" {
  let root = lay.row([
    lay.leaf(30.0, 30.0), lay.leaf(30.0, 30.0),
    lay.leaf(30.0, 30.0), lay.leaf(30.0, 30.0),
  ]) |> lay.with_size(100.0, UNDEF) |> lay.with_wrap(WRAP)
  let r = lay.layout(root, 100.0, UNDEF)
  // 3 fit in first row (30*3=90 < 100), 4th wraps to second row
  assert(approx(r[0].h, 60.0))
  assert(approx(r[1].x, 0.0))
  assert(approx(r[1].y, 0.0))
  assert(approx(r[2].x, 30.0))
  assert(approx(r[3].x, 60.0))
  assert(approx(r[4].y, 30.0))
  assert(approx(r[4].x, 0.0))
}

test "yoga: wrap_row_align_items_flex_end" {
  let root = lay.row([
    lay.leaf(30.0, 10.0), lay.leaf(30.0, 20.0),
    lay.leaf(30.0, 30.0), lay.leaf(30.0, 30.0),
  ]) |> lay.with_size(100.0, UNDEF) |> lay.with_wrap(WRAP) |> lay.with_align(lay.ALIGN_END)
  let r = lay.layout(root, 100.0, UNDEF)
  assert(approx(r[0].h, 60.0))
  // Line 1 cross=30. child0 h=10 → bottom-aligned: y=20
  assert(approx(r[1].y, 20.0))
  assert(approx(r[1].h, 10.0))
  assert(approx(r[2].y, 10.0))
  assert(approx(r[2].h, 20.0))
  assert(approx(r[3].y, 0.0))
  assert(approx(r[3].h, 30.0))
  // Line 2: y starts at 30
  assert(approx(r[4].y, 30.0))
}

test "yoga: wrap_row_align_items_center" {
  let root = lay.row([
    lay.leaf(30.0, 10.0), lay.leaf(30.0, 20.0),
    lay.leaf(30.0, 30.0), lay.leaf(30.0, 30.0),
  ]) |> lay.with_size(100.0, UNDEF) |> lay.with_wrap(WRAP) |> lay.with_align(lay.ALIGN_CENTER)
  let r = lay.layout(root, 100.0, UNDEF)
  // Line 1 cross=30. child0 h=10 → centered: y=10
  assert(approx(r[1].y, 10.0))
  assert(approx(r[2].y, 5.0))
  assert(approx(r[3].y, 0.0))
}

// ════════════════════════════════════════
// Align Content (multi-line)
// ════════════════════════════════════════

test "yoga: align_content_center_wrap" {
  let root = lay.row([
    lay.leaf(50.0, 10.0), lay.leaf(50.0, 10.0),
    lay.leaf(50.0, 10.0), lay.leaf(50.0, 10.0),
    lay.leaf(50.0, 10.0),
  ]) |> lay.with_size(140.0, 120.0) |> lay.with_wrap(WRAP)
     |> lay.with_align_content(lay.ALIGN_CENTER)
  let r = lay.layout(root, 140.0, 120.0)
  // 3 lines: [2 items, 2 items, 1 item], each 10h. total=30. free=90. offset=45.
  assert(approx(r[1].y, 45.0))
  assert(approx(r[2].y, 45.0))
  assert(approx(r[3].y, 55.0))
  assert(approx(r[5].y, 65.0))
}

test "yoga: align_content_stretch_row" {
  let root = lay.row([
    lay.leaf(50.0, UNDEF), lay.leaf(50.0, UNDEF),
    lay.leaf(50.0, UNDEF), lay.leaf(50.0, UNDEF),
    lay.leaf(50.0, UNDEF),
  ]) |> lay.with_size(150.0, 100.0) |> lay.with_wrap(WRAP)
     |> lay.with_align_content(lay.ALIGN_STRETCH)
  let r = lay.layout(root, 150.0, 100.0)
  // 2 lines: [3 items, 2 items]. Each line gets 50h (stretch).
  assert(approx(r[1].h, 50.0))
  assert(approx(r[4].y, 50.0))
  assert(approx(r[4].h, 50.0))
}

// ════════════════════════════════════════
// Align Items (additional)
// ════════════════════════════════════════

test "yoga: align_items_flex_end_column" {
  let root = lay.col([lay.leaf(10.0, 10.0)]) |> lay.with_size(100.0, 100.0) |> lay.with_align(lay.ALIGN_END)
  let r = lay.layout(root, 100.0, 100.0)
  assert(approx(r[1].x, 90.0))
  assert(approx(r[1].w, 10.0))
}

// ════════════════════════════════════════
// Min / Max (additional)
// ════════════════════════════════════════

test "yoga: min_height_with_flex_grow" {
  let c0 = lay.node_defaults() |> lay.with_grow(1.0) |> lay.with_min_size(0.0, 60.0)
  let c1 = lay.node_defaults() |> lay.with_grow(1.0)
  let root = lay.col([c0, c1]) |> lay.with_size(100.0, 100.0)
  let r = lay.layout(root, 100.0, 100.0)
  // c0 min=60 → clamped. c1 gets 40.
  // Probe: narrow down actual value
  assert(approx(r[1].h, 60.0))
  assert(approx(r[2].y, 60.0))
  assert(approx(r[2].h, 40.0))
}

test "yoga: max_height_with_flex_grow" {
  let root = lay.col([
    lay.node_defaults() |> lay.with_grow(1.0) |> lay.with_max_size(UNDEF, 30.0),
    lay.node_defaults() |> lay.with_grow(1.0),
  ]) |> lay.with_size(100.0, 100.0)
  let r = lay.layout(root, 100.0, 100.0)
  // Equal split=50, but child0 max=30 → child0=30, child1 gets rest=70.
  assert(approx(r[1].h, 30.0))
  assert(approx(r[2].h, 70.0))
}

test "yoga: flex_grow_within_constrained_min_row" {
  let c = lay.node_defaults() |> lay.with_grow(1.0) |> lay.with_min_size(60.0, 0.0)
  let root = lay.row([c, lay.leaf(50.0, UNDEF)]) |> lay.with_size(100.0, 100.0)
  let r = lay.layout(root, 100.0, 100.0)
  // child0 grow=1, basis=0, min=60. Remaining=100-50=50. grow→50, but min=60 → 60.
  assert(approx(r[1].w, 60.0))
}

// ════════════════════════════════════════
// Flex Basis (additional)
// ════════════════════════════════════════

test "yoga: flex_basis_overrides_width" {
  let c = lay.leaf(100.0, UNDEF) |> lay.with_basis(50.0)
  let root = lay.row([c]) |> lay.with_size(200.0, 100.0)
  let r = lay.layout(root, 200.0, 100.0)
  // basis=50 overrides width=100 for flex computation
  assert(approx(r[1].w, 50.0))
}

test "yoga: flex_basis_with_grow_and_shrink" {
  let c1 = lay.node_defaults() |> lay.with_flex(1.0, 1.0, 100.0)
  let c2 = lay.node_defaults() |> lay.with_flex(1.0, 1.0, 200.0)
  let root = lay.row([c1, c2]) |> lay.with_size(400.0, 100.0)
  let r = lay.layout(root, 400.0, 100.0)
  // basis 100+200=300, remaining=100. grow 1:1 → +50 each.
  assert(approx(r[1].w, 150.0))
  assert(approx(r[2].w, 250.0))
}

// ════════════════════════════════════════
// Display None (additional)
// ════════════════════════════════════════

test "yoga: display_none_with_margin" {
  let root = lay.row([
    lay.leaf(50.0, 50.0),
    lay.leaf(50.0, 50.0) |> lay.with_display(lay.DISPLAY_NONE),
    lay.leaf(50.0, 50.0),
  ]) |> lay.with_size(200.0, 100.0)
  let r = lay.layout(root, 200.0, 100.0)
  // Middle child hidden: third child at x=50 (no gap from hidden)
  assert(approx(r[2].x, 50.0))
}

// ════════════════════════════════════════
// Margin (additional)
// ════════════════════════════════════════

test "yoga: margin_bottom_with_justify_end" {
  let c = lay.leaf(UNDEF, 10.0) |> lay.with_margin({ top: 0.0, right: 0.0, bottom: 10.0, left: 0.0 })
  let root = lay.col([c]) |> lay.with_size(100.0, 100.0) |> lay.with_justify(lay.JUSTIFY_END)
  let r = lay.layout(root, 100.0, 100.0)
  assert(approx(r[1].y, 80.0))  // 100 - 10(h) - 10(margin)
}

test "yoga: margin_cross_axis_center" {
  let c = lay.leaf(50.0, 50.0) |> lay.with_margin({ top: 10.0, right: 0.0, bottom: 10.0, left: 0.0 })
  let root = lay.row([c]) |> lay.with_size(100.0, 100.0) |> lay.with_align(lay.ALIGN_CENTER)
  let r = lay.layout(root, 100.0, 100.0)
  // Cross avail=100, child h=50, margin t+b=20. free=30. center → 10 + 15 = 25
  assert(approx(r[1].y, 25.0))
}

// ════════════════════════════════════════
// Nested (additional)
// ════════════════════════════════════════

test "yoga: nested_flex_grow" {
  let inner = lay.row([
    lay.node_defaults() |> lay.with_grow(1.0),
    lay.node_defaults() |> lay.with_grow(2.0),
  ])
  let root = lay.col([
    inner |> lay.with_grow(1.0),
    lay.leaf(UNDEF, 50.0),
  ]) |> lay.with_size(300.0, 200.0)
  let r = lay.layout(root, 300.0, 200.0)
  // root col 200h: inner grow=1 → 150h, bottom leaf 50h.
  assert(approx(r[1].h, 150.0))
  // inner row 300w: child0 grow=1 → 100w, child1 grow=2 → 200w.
  assert(approx(r[2].w, 100.0))
  assert(approx(r[3].w, 200.0))
}

// ════════════════════════════════════════
// Padding

test "yoga: padding_no_child" {
  let root = lay.node_defaults() |> lay.with_padding(lay.edges_all(10.0))
  let r = lay.layout(root, 100.0, 100.0)
  assert(approx(r[0].w, 100.0))
  assert(approx(r[0].h, 100.0))
}

test "yoga: padding_with_child" {
  let root = lay.row([lay.leaf(50.0, 50.0)]) |> lay.with_padding(lay.edges_all(10.0))
  let r = lay.layout(root, 200.0, 200.0)
  assert(approx(r[1].x, 10.0))
  assert(approx(r[1].y, 10.0))
}

// ════════════════════════════════════════
// Justify Content (comprehensive)
// ════════════════════════════════════════

test "yoga: justify_content_space_around" {
  let root = lay.row([lay.leaf(50.0, 50.0), lay.leaf(50.0, 50.0)])
             |> lay.with_size(300.0, 100.0) |> lay.with_justify(lay.JUSTIFY_AROUND)
  let r = lay.layout(root, 300.0, 100.0)
  // free = 300 - 100 = 200. space = 200/2 = 100. offset = 50.
  assert(approx(r[1].x, 50.0))
  assert(approx(r[2].x, 200.0))  // 50 + 50 + 100
}

test "yoga: justify_content_space_evenly" {
  let root = lay.row([lay.leaf(50.0, 50.0), lay.leaf(50.0, 50.0)])
             |> lay.with_size(300.0, 100.0) |> lay.with_justify(lay.JUSTIFY_EVENLY)
  let r = lay.layout(root, 300.0, 100.0)
  assert(approx(r[1].x, 66.7))
  assert(approx(r[2].x, 183.3))
}

// ════════════════════════════════════════
// Border
// ════════════════════════════════════════

test "yoga: border_no_size" {
  let root = lay.node_defaults() |> lay.with_border(lay.edges_all(10.0))
  let r = lay.layout(root, UNDEF, UNDEF)
  assert(approx(r[0].w, 20.0))
  assert(approx(r[0].h, 20.0))
}

test "yoga: border_container_match_child" {
  let root = lay.col([lay.leaf(10.0, 10.0)])
    |> lay.with_border(lay.edges_all(10.0)) |> lay.with_size(30.0, 30.0)
  let r = lay.layout(root, 30.0, 30.0)
  assert(approx(r[1].x, 10.0))
  assert(approx(r[1].y, 10.0))
}

test "yoga: border_flex_child" {
  let root = lay.col([lay.leaf(10.0, UNDEF) |> lay.with_grow(1.0)])
    |> lay.with_border(lay.edges_all(10.0)) |> lay.with_size(100.0, 100.0)
  let r = lay.layout(root, 100.0, 100.0)
  assert(approx(r[1].x, 10.0))
  assert(approx(r[1].y, 10.0))
  assert(approx(r[1].w, 10.0))
  assert(approx(r[1].h, 80.0))
}

test "yoga: border_stretch_child" {
  let root = lay.col([lay.leaf(UNDEF, 10.0)])
    |> lay.with_border(lay.edges_all(10.0)) |> lay.with_size(100.0, 100.0)
  let r = lay.layout(root, 100.0, 100.0)
  assert(approx(r[1].x, 10.0))
  assert(approx(r[1].y, 10.0))
  assert(approx(r[1].w, 80.0))
  assert(approx(r[1].h, 10.0))
}

