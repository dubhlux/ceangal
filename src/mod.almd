  sc.set_scrollbar_frac(sc.ax(region, sc.AXIS_Y), frac, sc.rgn_content_h[region], sc.rgn_bounds_h[region])
  draw_at_scroll()
}

@export(wasm, "region_count")
fn get_region_count() -> Int = sc.region_count

// Region bounds in CSS px (for JS hit test)
@export(wasm, "region_screen_x")
fn region_screen_x(region: Int) -> Float = sc.rgn_bounds_x[region] + sc.ax_pos[sc.ax(sc.rgn_parent[region], sc.AXIS_X)]
@export(wasm, "region_screen_y")
fn region_screen_y(region: Int) -> Float = sc.rgn_bounds_y[region] + sc.ax_pos[sc.ax(sc.rgn_parent[region], sc.AXIS_Y)]
@export(wasm, "region_w")
fn region_w(region: Int) -> Float = sc.rgn_bounds_w[region]
@export(wasm, "region_h")
fn region_h(region: Int) -> Float = sc.rgn_bounds_h[region]

