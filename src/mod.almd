// ceangal — UI framework for Almide
//
// Orchestration layer: scene lifecycle, scroll API exports, DOM overlay.
// Rendering via snaidhm, scroll physics via self.scroll.

import self.dom as dom
import self.layout as layout
import self.scroll as sc
import self.virtual_list as vlist
import self.todoapp as td
import self.render as render
import self.cell as cl
import snaidhm
import snaidhm.web.gpu as gpu
import snaidhm.ttf as ttf

// ── Scene cache ──

var cached_scene: snaidhm.SceneHandle = {
  device: 0, width: 0, height: 0, viewport_tiles_x: 0, viewport_tiles_y: 0,
  params_buf: 0, regions_buf: 0, pixel_buf: 0,
  items_buf: 0,
  compute_pipeline: 0, compute_bg: 0, compute_regions_bg: 0,
  quad_pipeline: 0, quad_bg: 0, quad_regions_bg: 0,
  img_pipeline: 0, img_bg: 0,
  img_vtx: 0, img_idx: 0, img_count: 0, format: 0,
}
var scene_ready = false
var viewport_w = 0.0
var viewport_h = 0.0
var root_region = 0
var focused_region = 0

// Pre-allocated region upload lists (avoid per-frame allocation)
var rgn_bx: List[Float] = list.repeat(0.0, 8)
var rgn_by: List[Float] = list.repeat(0.0, 8)
var rgn_bw: List[Float] = list.repeat(0.0, 8)
var rgn_bh: List[Float] = list.repeat(0.0, 8)
var rgn_sx: List[Float] = list.repeat(0.0, 8)
var rgn_sy: List[Float] = list.repeat(0.0, 8)
var rgn_cw: List[Float] = list.repeat(0.0, 8)
var rgn_ch: List[Float] = list.repeat(0.0, 8)
var rgn_pa: List[Int] = list.repeat(0 - 1, 8)
var rgn_boy: List[Float] = list.repeat(0.0, 8)
var rgn_box: List[Float] = list.repeat(0.0, 8)

// ── Render items upload ──

fn upload_render_items(vw: Float, vh: Float) -> Unit = {
  let view = td.app()
  let items = render.render(view, vw, vh)
  cached_items = items
  let count = list.len(items)
  let s = dpr()
  var xs: List[Float] = []
  var ys: List[Float] = []
  var ws: List[Float] = []
  var hs: List[Float] = []
  var bg_rs: List[Float] = []
  var bg_gs: List[Float] = []
  var bg_bs: List[Float] = []
  var bg_as: List[Float] = []
  var roundeds: List[Float] = []
  var opacities: List[Float] = []
  for item in items {
    xs = xs + [item.x * s]
    ys = ys + [item.y * s]
    ws = ws + [item.w * s]
    hs = hs + [item.h * s]
    bg_rs = bg_rs + [item.bg_r]
    bg_gs = bg_gs + [item.bg_g]
    bg_bs = bg_bs + [item.bg_b]
    bg_as = bg_as + [item.bg_a]
    roundeds = roundeds + [item.rounded * s]
    opacities = opacities + [item.opacity]
  }
  snaidhm.upload_items(cached_scene, count, xs, ys, ws, hs, bg_rs, bg_gs, bg_bs, bg_as, roundeds, opacities)
}

// ── Drawing ──

fn dpr() -> Float = int.to_float(cached_scene.height) / viewport_h

fn draw_at_scroll() -> Unit = {
  if scene_ready then {
    let s = dpr()
    let ry = sc.ax(root_region, sc.AXIS_Y)
    let rx = sc.ax(root_region, sc.AXIS_X)

    // Upload region scroll data (using pre-allocated lists)
    for i in 0..sc.region_count {
      rgn_bx[i] = sc.rgn_bounds_x[i] * s
      rgn_by[i] = sc.rgn_bounds_y[i] * s
      rgn_bw[i] = sc.rgn_bounds_w[i] * s
      rgn_bh[i] = sc.rgn_bounds_h[i] * s
      rgn_sx[i] = sc.ax_pos[sc.ax(i, sc.AXIS_X)] * s
      rgn_sy[i] = sc.ax_pos[sc.ax(i, sc.AXIS_Y)] * s
      rgn_cw[i] = sc.rgn_content_w[i] * s
      rgn_ch[i] = sc.rgn_content_h[i] * s
      rgn_pa[i] = sc.rgn_parent[i]
      rgn_boy[i] = sc.ax_bar_opacity[sc.ax(i, sc.AXIS_Y)]
      rgn_box[i] = sc.ax_bar_opacity[sc.ax(i, sc.AXIS_X)]
    }
    snaidhm.upload_regions(cached_scene, sc.region_count, rgn_bx, rgn_by, rgn_bw, rgn_bh, rgn_sx, rgn_sy, rgn_cw, rgn_ch, rgn_pa, rgn_boy, rgn_box)

    // Write virtual list params to GPU (item_height in physical px, item_count)
    gpu.write_f32_at(cached_scene.device, cached_scene.params_buf, 56, 0.0)
    gpu.write_f32_at(cached_scene.device, cached_scene.params_buf, 60, 0.0)

    snaidhm.draw_frame_2d(cached_scene,
      sc.ax_pos[rx] * s, sc.ax_pos[ry] * s,
      sc.ax_bar_opacity[ry], sc.ax_bar_opacity[rx],
      sc.ax_bar_hover[ry], sc.ax_bar_hover[rx])
  } else ()
}

// ── Prepare ──

// Internal: prepare GPU scene from virtual list window
@export(wasm, "prepare_scene")
fn do_prepare(device: Int, css_w: Int, css_h: Int, phys_w: Int, phys_h: Int,
              img_vtx: Int, img_idx: Int, img_count: Int, img_texture: Int, img_sampler: Int) -> Unit = {
  let vw = int.to_float(css_w)
  let vh = int.to_float(css_h)
  viewport_w = vw
  viewport_h = vh

  // Prepare empty scene (virtual list items rendered procedurally in WGSL)
  let data = build_empty_scene(vw, vh)
  let d = int.to_float(phys_h) / vh
  cached_scene = snaidhm.prepare_scene(device, phys_w, phys_h, phys_w, phys_h,
    data.cubics, data.shadows, data.paints,
    img_vtx, img_idx, img_count, img_texture, img_sampler)
  scene_ready = true

  td.add_todo("Buy milk")
  td.add_todo("Write docs")
  upload_render_items(vw, vh)

  // Init virtual list (disabled, using todo app)
  vlist.init(0, 0.0, vw, vh)

  // Scroll setup
  sc.reset_all()
  root_region = sc.create_region(vw, vlist.content_height(), vw, vh, 0 - 1)
  focused_region = root_region

  draw_at_scroll()
}

// ── Scroll position accessor ──

@export(wasm, "get_scroll_pos")
fn get_scroll_pos(region: Int, axis: Int) -> Float = sc.get_pos(region, axis)

// ── Unified hit test ──
// Returns type * 256 + region_id
// Types: 0=none, 1=region, 2=thumb_y, 3=thumb_x, 4=track_y, 5=track_x

@export(wasm, "hit_test")
fn do_hit_test(x: Float, y: Float) -> Int = sc.full_hit_test(x, y)

@export(wasm, "scrollbar_drag_to")
fn do_scrollbar_drag_to(region: Int, axis: Int, screen_pos: Float) -> Unit = {
  sc.scrollbar_drag_to(region, axis, screen_pos)
  draw_at_scroll()
}

@export(wasm, "track_tap_at")
fn do_track_tap_at(region: Int, axis: Int, screen_pos: Float) -> Unit = {
  sc.track_tap_at(region, axis, screen_pos)
  draw_at_scroll()
}

// ── Scroll event exports ──

@export(wasm, "scroll_wheel")
fn scroll_wheel(region: Int, dx: Float, dy: Float) -> Unit = {
  sc.route_wheel(region, dx, dy)
  draw_at_scroll()
}

@export(wasm, "scroll_drag")
fn scroll_drag(region: Int, dy: Float) -> Unit = {
  sc.route_drag(region, dy)
  draw_at_scroll()
}

@export(wasm, "scroll_release")
fn scroll_release(region: Int, vel: Float) -> Unit = sc.route_release(region, vel)

@export(wasm, "scroll_tick")
fn scroll_tick(dt: Float) -> Int = {
  let running = sc.tick_all(dt)
  draw_at_scroll()
  running
}

// ── Scrollbar exports (any region by ID) ──

